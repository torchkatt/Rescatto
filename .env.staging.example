# Variables de entorno para staging
# Copiar a .env.staging.local y rellenar con los valores del proyecto rescatto-staging

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=rescatto-staging.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=rescatto-staging
VITE_FIREBASE_STORAGE_BUCKET=rescatto-staging.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_VAPID_KEY=

