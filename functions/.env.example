# === Secretos de producción ===
# Configurar con: firebase functions:secrets:set NOMBRE_VARIABLE
#
# Wompi — obtener en https://comercios.wompi.co/ → Settings → API Keys
WOMPI_INTEGRITY_SECRET=prod_integrity_...
WOMPI_PUBLIC_KEY=pub_prod_...
#
# SendGrid — obtener en https://app.sendgrid.com/ → Settings → API Keys
SENDGRID_KEY=SG.xxx...
#
# AI — DeepSeek (primario) o Gemini (fallback)
# Obtener en https://platform.deepseek.com y https://aistudio.google.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# === Variables no-sensibles ===
SENDGRID_FROM=noreply@rescatto.com
