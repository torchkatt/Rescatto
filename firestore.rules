rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPER FUNCTIONS ────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return (isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid))) 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data 
        : null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (getUserData() != null && 
         (getUserData().role == 'SUPER_ADMIN' || getUserData().role == 'ADMIN' || 
          (('activeMembershipId' in getUserData() && getUserData().activeMembershipId != null) ? 
           get(/databases/$(database)/documents/memberships/$(getUserData().activeMembershipId)).data.role in ['SUPER_ADMIN', 'ADMIN'] : 
           false)));
    }

    function isSuperAdmin() {
      return isAuthenticated() && 
        (getUserData() != null && 
         (getUserData().role == 'SUPER_ADMIN' || 
          (('activeMembershipId' in getUserData() && getUserData().activeMembershipId != null) ? 
           get(/databases/$(database)/documents/memberships/$(getUserData().activeMembershipId)).data.role == 'SUPER_ADMIN' : 
           false)));
    }

    function hasRole(roleName) {
      return isAuthenticated() && 
        (getUserData() != null && 
         (getUserData().role == roleName || 
          (('activeMembershipId' in getUserData() && getUserData().activeMembershipId != null) ? 
           get(/databases/$(database)/documents/memberships/$(getUserData().activeMembershipId)).data.role == roleName : 
           false)));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function canUserCreateOwnProfile(userId) {
      return isOwner(userId) &&
        request.resource.data.role == 'CUSTOMER' &&
        request.resource.data.keys().hasAll([
          'fullName',
          'email',
          'role',
          'createdAt'
        ]) &&
        request.resource.data.keys().hasOnly([
          'fullName',
          'email',
          'role',
          'createdAt',
          'referralCode',
          'invitedBy',
          'isGuest',
          'avatarUrl',
          'hasSeenOnboarding',
          'fcmToken',
          'lastTokenUpdate'
        ]) &&
        (
          (request.auth.token.email != null && request.resource.data.email == request.auth.token.email) ||
          (request.auth.token.email == null && request.resource.data.email == null)
        );
    }

    function canUserUpdateOwnProfile(userId) {
      return isOwner(userId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'fullName',
          'phone',
          'address',
          'city',
          'avatarUrl',
          'hasSeenOnboarding',
          'fcmToken',
          'lastTokenUpdate',
          'updatedAt'
        ]);
    }

    function canUserConvertGuest(userId) {
      return isOwner(userId) &&
        resource.data.isGuest != false &&
        request.resource.data.isGuest == false &&
        request.resource.data.email == request.auth.token.email &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'fullName',
          'email',
          'isGuest'
        ]);
    }

    function canUserSyncVerification(userId) {
      return isOwner(userId) &&
        request.auth.token.email_verified == true &&
        request.resource.data.isVerified == true &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'isVerified',
          'verificationDate'
        ]);
    }

    function belongsToVenue(venueId) {
      return isAuthenticated() && (
        (
          getUserData() != null &&
          getUserData().role in ['VENUE_OWNER', 'KITCHEN_STAFF'] &&
          (getUserData().venueId == venueId || ('venueIds' in getUserData() && venueId in getUserData().venueIds))
        ) ||
        (
          (getUserData() != null && 'activeMembershipId' in getUserData() && getUserData().activeMembershipId != null) ?
          (get(/databases/$(database)/documents/memberships/$(getUserData().activeMembershipId)).data.role in ['VENUE_OWNER', 'KITCHEN_STAFF'] &&
           get(/databases/$(database)/documents/memberships/$(getUserData().activeMembershipId)).data.venueId == venueId) :
          false
        )
      );
    }

    function isVenueOwnerOf(venueId) {
      return isAuthenticated() && (
        (getUserData() != null && getUserData().role == 'VENUE_OWNER' && (getUserData().venueId == venueId || ('venueIds' in getUserData() && venueId in getUserData().venueIds))) ||
        (
          (getUserData() != null && 'activeMembershipId' in getUserData() && getUserData().activeMembershipId != null) ?
          (get(/databases/$(database)/documents/memberships/$(getUserData().activeMembershipId)).data.role == 'VENUE_OWNER' &&
           get(/databases/$(database)/documents/memberships/$(getUserData().activeMembershipId)).data.venueId == venueId) :
          false
        )
      );
    }

    function isKitchenStaffOf(venueId) {
      return isAuthenticated() && (
        (getUserData() != null && getUserData().role == 'KITCHEN_STAFF' && (getUserData().venueId == venueId || ('venueIds' in getUserData() && venueId in getUserData().venueIds))) ||
        (
          (getUserData() != null && 'activeMembershipId' in getUserData() && getUserData().activeMembershipId != null) ?
          (get(/databases/$(database)/documents/memberships/$(getUserData().activeMembershipId)).data.role == 'KITCHEN_STAFF' &&
           get(/databases/$(database)/documents/memberships/$(getUserData().activeMembershipId)).data.venueId == venueId) :
          false
        )
      );
    }

    // ─── SCHEMA VALIDATION HELPERS ──────────────────────────────────────

    function isValidAuditLog() {
      return request.resource.data.keys().hasAll(['performedBy', 'action', 'timestamp']) &&
             request.resource.data.keys().hasOnly([
               'performedBy', 'action', 'timestamp', 'userRole', 'details', 'path', 
               'userAgent', 'device', 'metadata', 'targetId', 'targetCollection'
             ]) &&
             request.resource.data.performedBy is string &&
             request.resource.data.action is string;
    }

    function isValidUser() {
      return request.resource.data.keys().hasAll(['fullName', 'role', 'createdAt']) &&
             request.resource.data.role in ['CUSTOMER', 'ADMIN', 'VENUE_OWNER', 'KITCHEN_STAFF', 'DRIVER', 'SUPER_ADMIN'];
    }


    // ─── ROOT STATS ──────────────────────────────────────────────────────
    match /stats/{statId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions can write here (e.g. aggregateAdminStats)
    }

    // ─── USERS ───────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      // Allow any authenticated user to create their own profile.
      // Guest users (anonymous) need this to initialize their documents.
      allow create: if isOwner(userId) && isValidUser();

      // Allow profile updates and sync verification.
      // Also allow updating activeMembershipId during initial setup.
      allow update: if (isAdmin()
        || isOwner(userId)
        || canUserSyncVerification(userId)) && isValidUser();

      allow delete: if isSuperAdmin();

      // Stats subcollection (e.g. users/{userId}/stats/ratings)
      match /stats/{statId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false; // Updated by Cloud Functions only
      }
    }

    // ─── MEMBERSHIPS (V2 Architecture) ───────────────────────────────────

    match /memberships/{membershipId} {
      // Users can read their own memberships. Admins can read all.
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      // For now, only Cloud Functions (Admin SDK) or existing Admins can create/update memberships 
      // except for the user auto-creating their first CUSTOMER membership during signup.
      allow create: if isAdmin() || (
        isAuthenticated() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.role == 'CUSTOMER'
      );
      // Users can only update their own membership status (e.g. deactivate), 
      // but modifying roles or venueId requires Admin permissions.
      allow update: if isAdmin() || (
        isAuthenticated() && 
        resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
      );
      allow delete: if isSuperAdmin();
    }


    // ─── VENUES ──────────────────────────────────────────────────────────

    match /venues/{venueId} {
      allow read: if true; // Marketplace visibility for guests
      allow update: if isVenueOwnerOf(venueId) || isAdmin();
      allow create, delete: if isAdmin();

      // Stats subcollection
      match /stats/{statId} {
        allow read: if true;
        // Only customers and admins can update rating stats (after creating a rating)
        // Revenue/orders stats are Cloud Function only (statId != 'ratings' is blocked)
        allow write: if statId == 'ratings' &&
          (isSuperAdmin() || (isAuthenticated() && getUserData() != null && getUserData().role == 'CUSTOMER'));
      }
    }


    // ─── PRODUCTS ────────────────────────────────────────────────────────

    match /products/{productId} {
      allow read: if true; // Visible to guests

      allow create: if isAdmin() ||
        (hasRole('VENUE_OWNER') &&
         belongsToVenue(request.resource.data.venueId));

      allow update: if isAdmin() ||
        isVenueOwnerOf(resource.data.venueId);
        
      allow delete: if isAdmin() ||
        isVenueOwnerOf(resource.data.venueId);
    }


    // ─── ORDERS ──────────────────────────────────────────────────────────

    match /orders/{orderId} {

      // Driver puede leer un pedido AWAITING_DRIVER de su misma ciudad
      function isDriverAvailableOrder(data) {
        return data.deliveryMethod == 'delivery' &&
          (data.driverId == null || data.driverId == request.auth.uid) &&
          data.status == 'AWAITING_DRIVER';
      }

      // Driver toma un pedido del pool (AWAITING_DRIVER → DRIVER_ASSIGNED, atómico)
      function canDriverTakeOrder() {
        return hasRole('DRIVER') &&
          resource.data.status == 'AWAITING_DRIVER' &&
          resource.data.driverId == null &&
          request.resource.data.driverId == request.auth.uid &&
          request.resource.data.status == 'DRIVER_ASSIGNED' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'driverId',
            'driverName',
            'status',
            'acceptedAt',
            'updatedAt'
          ]);
      }

      // Driver inicia tránsito (DRIVER_ASSIGNED → IN_TRANSIT)
      function canDriverStartTransit() {
        return hasRole('DRIVER') &&
          resource.data.driverId == request.auth.uid &&
          request.resource.data.driverId == request.auth.uid &&
          resource.data.status == 'DRIVER_ASSIGNED' &&
          request.resource.data.status == 'IN_TRANSIT' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'pickedUpAt',
            'updatedAt'
          ]);
      }

      // Driver marca como entregado (IN_TRANSIT → awaitingClientConfirmation)
      function canDriverMarkDelivered() {
        return hasRole('DRIVER') &&
          resource.data.driverId == request.auth.uid &&
          request.resource.data.driverId == request.auth.uid &&
          resource.data.status == 'IN_TRANSIT' &&
          request.resource.data.status == 'IN_TRANSIT' &&
          request.resource.data.awaitingClientConfirmation == true &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'awaitingClientConfirmation',
            'driverMarkedCompletedAt',
            'updatedAt'
          ]);
      }

      // Driver completa el pedido directamente (IN_TRANSIT → COMPLETED, fallback sin confirmación cliente)
      function canDriverCompleteOrder() {
        return hasRole('DRIVER') &&
          resource.data.driverId == request.auth.uid &&
          request.resource.data.driverId == request.auth.uid &&
          resource.data.status == 'IN_TRANSIT' &&
          request.resource.data.status == 'COMPLETED' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'deliveredAt',
            'deliveryNotes',
            'awaitingClientConfirmation',
            'updatedAt'
          ]);
      }

      // Cliente confirma recogida en local (READY → COMPLETED)
      function canCustomerConfirmPickup() {
        return isAuthenticated() &&
          resource.data.customerId == request.auth.uid &&
          resource.data.deliveryMethod != 'delivery' &&
          resource.data.status == 'READY' &&
          request.resource.data.status == 'COMPLETED' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'receivedAt',
            'updatedAt'
          ]);
      }

      // Cliente confirma entrega por domicilio (awaitingClientConfirmation → COMPLETED)
      function canCustomerConfirmDelivery() {
        return isAuthenticated() &&
          resource.data.customerId == request.auth.uid &&
          resource.data.awaitingClientConfirmation == true &&
          request.resource.data.status == 'COMPLETED' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'awaitingClientConfirmation',
            'receivedAt',
            'updatedAt'
          ]);
      }

      // Cliente disputa una entrega marcada por driver
      function canCustomerDisputeDelivery() {
        return isAuthenticated() &&
          resource.data.customerId == request.auth.uid &&
          resource.data.awaitingClientConfirmation == true &&
          request.resource.data.status == 'DISPUTED' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'awaitingClientConfirmation',
            'disputedAt',
            'disputeReason',
            'updatedAt'
          ]);
      }

      // Cliente cancela su pedido (solo cuando está en PENDING, antes de ser aceptado)
      function canCustomerCancelOrder() {
        return isAuthenticated() &&
          resource.data.customerId == request.auth.uid &&
          resource.data.status == 'PENDING' &&
          request.resource.data.status == 'CANCELLED' &&
          request.resource.data.cancellationReason == 'CLIENT_CANCELLED' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'cancellationReason',
            'cancelledAt',
            'updatedAt'
          ]);
      }

      // Venue/Kitchen actualizan el estado del pedido
      function isValidVenueStatusTransition(current, next, deliveryMethod, deliveryModel) {
        return
          // PENDING → ACCEPTED (negocio acepta el pedido)
          (current == 'PENDING' && next == 'ACCEPTED') ||
          // ACCEPTED → IN_PREPARATION (opcional, para negocios que cocinan)
          (current == 'ACCEPTED' && next == 'IN_PREPARATION') ||
          // ACCEPTED / IN_PREPARATION → READY
          ((current == 'ACCEPTED' || current == 'IN_PREPARATION') && next == 'READY') ||
          // READY → IN_TRANSIT (domiciliarios propios, venue despacha directamente)
          (current == 'READY' && next == 'IN_TRANSIT' && deliveryModel == 'own_drivers') ||
          // READY → AWAITING_DRIVER (liberar al pool de la app)
          (current == 'READY' && next == 'AWAITING_DRIVER' && deliveryModel == 'platform_drivers') ||
          // READY → COMPLETED (pickup directo)
          (deliveryMethod != 'delivery' && current == 'READY' && next == 'COMPLETED') ||
          // PENDING → CANCELLED (staff rechaza)
          (current == 'PENDING' && next == 'CANCELLED');
      }

      function canVenueUpdateOrder() {
        return (isVenueOwnerOf(resource.data.venueId) || isKitchenStaffOf(resource.data.venueId)) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status', 'driverId', 'rejectedBy', 'cancellationReason', 'cancelledAt', 'updatedAt'
          ]) &&
          isValidVenueStatusTransition(
            resource.data.status,
            request.resource.data.status,
            resource.data.deliveryMethod,
            resource.data.deliveryModel
          );
      }

      // Customers read their own; venue staff read their venue's; drivers read assigned + pool
      // Note: isDriverAvailableOrder's driverId==null check is intentionally omitted here
      // because Firestore query-level auth can't guarantee it for list queries.
      // Write protection (canDriverTakeOrder) still enforces driverId==null before assignment.
      allow read: if isAdmin() ||
        (isAuthenticated() && resource.data.customerId == request.auth.uid) ||
        (isAuthenticated() && belongsToVenue(resource.data.venueId)) ||
        (hasRole('DRIVER') && (
          resource.data.driverId == request.auth.uid ||
          (resource.data.deliveryMethod == 'delivery' && resource.data.status == 'AWAITING_DRIVER')
        )) ||
        (hasRole('KITCHEN_STAFF') && belongsToVenue(resource.data.venueId));

      // Creación bloqueada desde cliente: Todos los pedidos deben pasar por la Cloud Function "createOrder"
      allow create: if false;

      allow update: if isAdmin() ||
        canVenueUpdateOrder() ||
        canDriverTakeOrder() ||
        canDriverStartTransit() ||
        canDriverMarkDelivered() ||
        canDriverCompleteOrder() ||
        canCustomerConfirmPickup() ||
        canCustomerConfirmDelivery() ||
        canCustomerDisputeDelivery() ||
        canCustomerCancelOrder();

      allow delete: if isSuperAdmin();
    }


    // ─── RATINGS ─────────────────────────────────────────────────────────

    match /ratings/{ratingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.auth.uid == request.resource.data.fromUserId &&
        request.resource.data.score >= 1 &&
        request.resource.data.score <= 5;
      allow update, delete: if false; // Ratings are immutable
    }


    // ─── CATEGORIES ──────────────────────────────────────────────────────

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── ROLES ───────────────────────────────────────────────────────────

    match /roles/{roleId} {
      allow read: if isAdmin();
      allow write: if isSuperAdmin();
    }


    // ─── SETTINGS ────────────────────────────────────────────────────────

    match /settings/{settingId} {
      // Platform config contains sensitive data (commission %, limits) — admins only
      allow read: if isAdmin();
      allow write: if isSuperAdmin();
    }


    // ─── WALLETS ─────────────────────────────────────────────────────────

    match /wallets/{walletId} {
      allow read: if belongsToVenue(walletId) || isAdmin();
      allow write: if false; // Only via Cloud Functions
    }


    // ─── WALLET TRANSACTIONS ─────────────────────────────────────────────

    match /wallet_transactions/{txId} {
      allow read: if isAdmin() ||
        (isAuthenticated() && getUserData() != null && (
          resource.data.venueId == getUserData().venueId ||
          (getUserData().venueIds != null && resource.data.venueId in getUserData().venueIds)
        ));
      allow write: if false; // Only via Cloud Functions
    }


    // ─── CHATS ───────────────────────────────────────────────────────────

    match /chats/{chatId} {
      allow read: if isAdmin() ||
        (isAuthenticated() && request.auth.uid in resource.data.participants);

      allow create: if isAuthenticated() &&
        request.auth.uid in request.resource.data.participants &&
        request.resource.data.participants.size() >= 2 &&
        (request.resource.data.type != 'admin-support' || isAdmin());

      allow update: if isAdmin() ||
        (isAuthenticated() && request.auth.uid in resource.data.participants);

      allow delete: if isAdmin();

      // ─── MESSAGES (subcollection of chats) ──────────────────────────
      match /messages/{messageId} {
        // Only chat participants can read messages
        allow read: if isAdmin() ||
          (isAuthenticated() &&
           request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);

        // Only participants can send messages, and must be the sender
        allow create: if isAuthenticated() &&
          request.auth.uid == request.resource.data.senderId &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        // Only sender can edit their message, or participants can mark as read
        allow update: if isAuthenticated() &&
          (request.auth.uid == resource.data.senderId ||
           (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']) &&
            request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants));

        allow delete: if isSuperAdmin();
      }

      // ─── TYPING (subcollection of chats) ────────────────────────────
      match /typing/{userId} {
        // Only chat participants can see who is typing
        allow read: if isAdmin() ||
          (isAuthenticated() &&
           request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);

        // Participants can only write their own typing status
        allow write: if isAuthenticated() &&
          request.auth.uid == userId &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }


    // ─── NOTIFICATIONS ───────────────────────────────────────────────────

    match /notifications/{notifId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());

      // Se crean desde backend (Cloud Functions) para evitar spoofing/spam.
      allow create: if false;

      // Users can only mark their own notifications as read
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);

      allow delete: if isAdmin() ||
        (isAuthenticated() && resource.data.userId == request.auth.uid);
    }


    // ─── AUDIT LOGS ──────────────────────────────────────────────────────

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      // Only allow creating a log entry for your own actions (prevents spoofing other users)
      allow create: if (isAuthenticated() || request.resource.data.performedBy == 'anonymous')
          && (request.resource.data.performedBy == request.auth.uid || request.resource.data.performedBy == 'anonymous' || request.resource.data.performedBy == request.auth.token.email)
          && isValidAuditLog();
      allow update, delete: if false;     // Immutable
    }


    // ─── FLASH DEALS ─────────────────────────────────────────────────────

    match /flash_deals/{dealId} {
      // Anyone can read active deals (public content, visible to guests too)
      allow read: if true;

      // Only admins and venue owners (for their own venue) can create flash deals
      allow create: if isAdmin() ||
        (hasRole('VENUE_OWNER') && belongsToVenue(request.resource.data.venueId));

      // Only admins and venue owners (for their own venue) can update/deactivate flash deals
      allow update: if isAdmin() ||
        (hasRole('VENUE_OWNER') && belongsToVenue(resource.data.venueId));

      allow delete: if isAdmin();
    }


    // ─── DONATION CENTERS ────────────────────────────────────────────────

    match /donation_centers/{centerId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }


    // ─── REDEMPTIONS ─────────────────────────────────────────────────────

    match /redemptions/{redemptionId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false; // Only via Cloud Functions (redeemPoints)
    }


    // ─── SYSTEM / INTERNAL COLLECTIONS ───────────────────────────────────
    // These are only written by Cloud Functions (Admin SDK bypasses rules).
    // Deny all direct client access to prevent enumeration.

    match /rate_limits/{docId} {
      allow read, write: if false;
    }

    match /webhook_dedup/{docId} {
      allow read, write: if false;
    }

    match /webhook_errors/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /rating_stats/{statsId} {
      allow read: if true;
      allow write: if false; // Updated by Cloud Functions (onRatingCreated)
    }

    // ─── CARTS ────────────────────────────────────────────────────────────
    // Each user owns their own cart document. Only readable/writable by owner.

    match /carts/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ─── SUBSCRIPTION REQUESTS ───────────────────────────────────────────────
    // Owner can read/create. Only Cloud Functions write status changes.
    // Admins can read all.

    match /subscription_requests/{requestId} {
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow update: if false; // Solo Cloud Functions
    }

    // ─── PAYMENT SETTINGS ────────────────────────────────────────────────────
    // Cualquier usuario autenticado puede leer los datos bancarios.
    // Solo Cloud Functions escriben (requieren OTP verificado).
    match /settings/payment_info {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ─── OTP VERIFICATIONS ───────────────────────────────────────────────────
    // Solo Cloud Functions — nunca el cliente directamente.
    match /otp_verifications/{adminId} {
      allow read, write: if false;
    }

  }
}
